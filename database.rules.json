{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || auth.uid === $uid)",

        "role": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50 && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
        },
        "department": {
          ".validate": "newData.isString() && newData.val().length <= 200 && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
        },
        "departmentId": {
          ".validate": "newData.isString() && newData.val().length <= 200 && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
        },
        "departmentType": {
          ".validate": "newData.isString() && newData.val().length <= 200 && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'active' || newData.val() === 'inactive') && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 254 && newData.val().matches(/^[^@]+@[^@]+\\.[^@]+$/)"
        }
      }
    },

    "courses": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "departments": {
      ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
    },

    "videos": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "videoLibrary": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "courseVideos": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "questions": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "videoQuizzes": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "videoQuizAttempts": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "userAssignments": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        "$courseId": {
          ".validate": "newData.hasChildren(['assigned'])"
        }
      }
    },

    "assignments": {
      ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')"
    },

    "completedCourses": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)"
      }
    },

    "progress": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)"
      }
    },

    "results": {
      ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin')",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || root.child('users/'+auth.uid).child('role').val() === 'departmentAdmin' || auth.uid === $uid)"
      }
    },

    "attempts": {
      ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')",
      "$uid": {
        ".read": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || auth.uid === $uid)",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin' || auth.uid === $uid)"
      }
    },

    "master": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')",
      "designations": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('users/'+auth.uid).child('role').val() === 'superAdmin' || root.child('users/'+auth.uid).child('role').val() === 'admin')"
      }
    }
  }
}
