{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superAdmin' || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "doubtThreads": {
      ".read": "auth != null",
      "$threadId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['createdBy', 'subject'])"
      }
    },

    "doubtMessages": {
      ".read": "auth != null",
      "$threadId": {
        ".read": "auth != null",
        "$messageId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId', 'message'])"
        }
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notifId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "courses": {
      ".read": "auth != null"
    },

    "departments": {
      ".read": "auth != null"
    }
  }
}
